  <div class="bookmarks-view" id="view-bookmarks">
    <div class="papers-list" id="bookmarks-list"></div>
  </div>

  <div class="profile-view" id="view-profile">
    <div class="profile-card">
      <div class="profile-avatar">C</div>
      <div class="profile-name">Chris Mensah</div>
      <div class="profile-meta">Level 100 · Computer Science · RIU</div>
      <div class="profile-stats">
        <div class="p-stat"><div class="p-stat-n" id="p-uploads">3</div><div class="p-stat-l">Uploaded</div></div>
        <div class="p-stat"><div class="p-stat-n" id="p-saved">0</div><div class="p-stat-l">Saved</div></div>
        <div class="p-stat"><div class="p-stat-n">12</div><div class="p-stat-l">Upvotes</div></div>
      </div>
    </div>
  </div>
</div>

